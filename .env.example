# ============================================================
# .env.example
# ------------------------------------------------------------
# Copie para .env (mesma pasta) e preencha com seus valores.
# O arquivo .env é ignorado pelo git (.gitignore).
# ============================================================

# ------------------------------------------------------------
# Ambiente
# ------------------------------------------------------------
# development | dev | local | test  → permite defaults locais (admin/admin123)
# staging | production              → exige DATABASE_URL ou DB_* explícitos
APP_ENV=development

# ------------------------------------------------------------
# Banco LOCAL (Docker) — usado por populate.py e como ORIGEM em migrate_to_supabase.py
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chembl_pubmed
DB_USER=admin
DB_PASSWORD=admin123
# DB_SSLMODE=require   # descomente se o local exigir SSL

# ------------------------------------------------------------
# Banco DESTINO (Supabase) — usado por migrate_to_supabase.py
# ------------------------------------------------------------
# IMPORTANTE: caracteres especiais na senha precisam ser URL-encoded.
#   @ → %40    : → %3A    / → %2F    # → %23    ? → %3F
#   & → %26    % → %25    espaço → %20
#
# Exemplo: senha "@Isradede123" vira "%40Isradede123" na URL.
#
# Porta 6543 = transaction pooler (apps stateless, queries curtas)
# Porta 5432 = session/direct      (migração de schema, transações longas) ← recomendado p/ esse script
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:%40Isradede123@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
